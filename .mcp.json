{
  "mcpServers": {
    "justice-companion": {
      "command": "node",
      "args": ["../../MCPs/justice-companion/dist/index.js"],
      "env": {
        "NODE_ENV": "development"
      }
    },
    "sequential-thinking": {
      "command": "node",
      "args": [
        "node_modules/@modelcontextprotocol/server-sequential-thinking/dist/index.js"
      ]
    },
    "memory": {
      "command": "node",
      "args": ["node_modules/@modelcontextprotocol/server-memory/dist/index.js"]
    },
    "filesystem": {
      "command": "node",
      "args": [
        "node_modules/@modelcontextprotocol/server-filesystem/dist/index.js",
        "."
      ],
      "env": {
        "ALLOWED_DIRECTORIES": "."
      }
    },
    "github": {
      "command": "node",
      "args": ["node_modules/@modelcontextprotocol/server-github/dist/index.js"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "sqlite": {
      "command": "node",
      "args": [
        "node_modules/mcp-server-sqlite/dist/index.js",
        "--db-path",
        "./justice.db"
      ]
    },
    "playwright": {
      "command": "node",
      "args": [
        "node_modules/@executeautomation/playwright-mcp-server/dist/index.js"
      ]
    },
    "puppeteer": {
      "command": "node",
      "args": ["node_modules/@modelcontextprotocol/server-puppeteer/dist/index.js"]
    },
    "context7": {
      "command": "node",
      "args": ["node_modules/@upstash/context7-mcp/dist/index.js"],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "tavily": {
      "command": "npx",
      "args": ["-y", "tavily-mcp"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "playwright-official": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "fetcher": {
      "command": "npx",
      "args": ["-y", "fetcher-mcp"]
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@brave/brave-search-mcp-server"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "exa": {
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      }
    }
  }
}
